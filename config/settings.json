{
  "mad_filter": {
    "window": 15,
    "threshold": 3.5
  },
  "kalman_filter": {
    "q": 1e-4,
    "r": 1e-1
  },
  "spectral_denoise": {
    "order": 4,
    "cutoff": 0.1
  },
  "physical_bounds": {
    "battery_voltage": [10.0, 35.0],
    "bus_current": [0.0, 10.0],
    "temp_celsius": [-60.0, 100.0],
    "rw_speed_rpm": [-5000.0, 5000.0],
    "sun_sensor_lux": [0.0, 20000.0]
  },
  "columns_to_process": [
    "battery_voltage",
    "bus_current",
    "temp_celsius",
    "rw_speed_rpm",
    "sun_sensor_lux"
  ]
}
